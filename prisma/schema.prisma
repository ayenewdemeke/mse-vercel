// ─── Abutment Internal Stability ──────────────────────────────────────────────

model AbutmentInternalStability {
  id        String   @id @default(cuid())
  projectId String
  designId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Material Properties
  bstemBatter Float
  bI          Float
  deltaS      Float
  gRFill      Float
  phiRFill    Float

  // EQ Parameters
  pga    Float
  fPgaEq Float
  kV     Float

  // Extensible Reinforcement Parameters
  phiPoGs   Float
  alphaGs   Float
  rcGs      Float
  c         Float
  phiPoGg   Float
  phiPoGgEe Float
  alphaGg   Float
  rcGg      Float
  y         Float
  maxDh     Float
  a         Float

  // Inextensible Reinforcement Parameters
  tSt     Float
  stSg    Float
  phiPoSg Float
  alphaSg Float
  rcSg    Float
  bSs     Float
  phiPoSs Float
  f2      Float
  alphaSs Float
  sh      Float

  // Design Height and Spacing
  minDesignHeight Float
  maxDesignHeight Float
  sV              Float

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  design  Design  @relation(fields: [designId], references: [id], onDelete: Cascade)
}

// ─── Wing Internal Stability ──────────────────────────────────────────────────

model WingInternalStability {
  id        String   @id @default(cuid())
  projectId String
  designId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Material Properties
  bstemBatter Float
  bI          Float
  deltaS      Float
  gRFill      Float
  phiRFill    Float

  // EQ Parameters
  pga    Float
  fPgaEq Float
  kV     Float

  // Extensible Reinforcement Parameters
  phiPoGs   Float
  alphaGs   Float
  rcGs      Float
  gStrip    Float
  c         Float
  phiPoGg   Float
  phiPoGgEe Float
  alphaGg   Float
  rcGg      Float
  y         Float
  a         Float
  maxDh     Float

  // Inextensible Reinforcement Parameters
  tSt     Float
  stSg    Float
  phiPoSg Float
  alphaSg Float
  rcSg    Float
  bSs     Float
  phiPoSs Float
  alphaSs Float
  sh      Float
  d60     Float
  d10     Float

  // Design Height and Spacing
  minDesignHeight Float
  maxDesignHeight Float
  sV              Float

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  design  Design  @relation(fields: [designId], references: [id], onDelete: Cascade)
}

// ─── Precast Panel Face Design ────────────────────────────────────────────────

model PanelFaceDesign {
  id        String   @id @default(cuid())
  projectId String
  designId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Material Properties
  fc Float
  fy Float

  // Panel Geometry
  lPanel    Float
  hPanel    Float
  tPanel    Float
  ssr       Float
  cCoverPos Float
  cCoverNeg Float

  // Reinforcement (bar number and spacing)
  barNumVert  Float
  spacingVert Float
  barNumHor   Float
  spacingHor  Float

  // Loads from internal stability analysis
  huStr Float
  huEe  Float

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  design  Design  @relation(fields: [designId], references: [id], onDelete: Cascade)
}
