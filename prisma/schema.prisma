generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedProjects Project[]  @relation("ProjectOwner")
  memberships   Member[]   @relation("MemberUser")
  createdMembers Member[]  @relation("MemberCreator")
  documents     Document[]
  designs       Design[]
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  location    String
  latitude    Float?
  longitude   Float?
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User       @relation("ProjectOwner", fields: [userId], references: [id], onDelete: Cascade)
  members   Member[]
  documents Document[]
  designs   Design[]

  abutmentDesigns  AbutmentDesign[]
  wingDesigns      WingDesign[]
  panelFaceDesigns PanelFaceDesign[]
}

// ─── Team ─────────────────────────────────────────────────────────────────────

model MemberRole {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]
}

model Member {
  id           String   @id @default(cuid())
  creatorId    String
  userId       String
  projectId    String
  memberRoleId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator    User       @relation("MemberCreator", fields: [creatorId], references: [id])
  user       User       @relation("MemberUser", fields: [userId], references: [id], onDelete: Cascade)
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberRole MemberRole @relation(fields: [memberRoleId], references: [id])

  @@unique([userId, projectId])
}

// ─── Documents ────────────────────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  name        String
  file        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  uploader User    @relation(fields: [userId], references: [id])
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Designs ──────────────────────────────────────────────────────────────────

model DesignType {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designs Design[]
}

model Design {
  id           String   @id @default(cuid())
  userId       String
  projectId    String
  designTypeId String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator    User       @relation(fields: [userId], references: [id])
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  designType DesignType @relation(fields: [designTypeId], references: [id])

  abutmentDesign  AbutmentDesign?
  wingDesign      WingDesign?
  panelFaceDesign PanelFaceDesign?
}

// ─── Abutment Design (external + internal merged) ─────────────────────────────

model AbutmentDesign {
  id        String   @id @default(cuid())
  projectId String
  designId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // LS Moment Arm
  yev  Float
  ylsV Float

  // Geometry & Materials
  bstemBatter Float
  bI          Float
  deltaS      Float
  gRFill      Float
  phiRFill    Float

  // External-only (foundation / bearing)
  sigmaBrg Float
  phiFSoil Float

  // EQ Parameters
  pga    Float
  fPgaEq Float
  kV     Float

  // Extensible Reinforcement — Geosynthetic Strip
  phiPoGs Float
  alphaGs Float
  rcGs    Float
  c       Float

  // Extensible Reinforcement — Geosynthetic Grid
  phiPoGg   Float
  phiPoGgEe Float
  alphaGg   Float
  rcGg      Float
  y         Float
  maxDh     Float
  a         Float

  // Inextensible Reinforcement — Steel Grid
  tSt     Float
  stSg    Float
  phiPoSg Float
  alphaSg Float
  rcSg    Float

  // Inextensible Reinforcement — Steel Strip
  bSs     Float
  phiPoSs Float
  f2      Float
  alphaSs Float
  sh      Float

  // Design Heights and Spacing
  minDesignHeight Float
  maxDesignHeight Float
  sV              Float
  minRl           Float @default(8)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  design  Design  @relation(fields: [designId], references: [id], onDelete: Cascade)
}

// ─── Wing Design (external w/ LL + external w/o LL + internal merged) ─────────

model WingDesign {
  id        String   @id @default(cuid())
  projectId String
  designId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // LS Moment Arm
  yev  Float
  ylsV Float

  // Geometry & Materials
  bstemBatter Float
  theta       Float
  bI          Float
  deltaS      Float
  gRFill      Float
  phiRFill    Float

  // External-only (foundation / bearing)
  sigmaBrg Float
  phiFSoil Float

  // EQ Parameters
  pga    Float
  fPgaEq Float
  kV     Float

  // Extensible Reinforcement — Geosynthetic Strip
  phiPoGs Float
  alphaGs Float
  rcGs    Float
  gStrip  Float
  c       Float

  // Extensible Reinforcement — Geosynthetic Grid
  phiPoGg   Float
  phiPoGgEe Float
  alphaGg   Float
  rcGg      Float
  y         Float
  a         Float
  maxDh     Float

  // Inextensible Reinforcement — Steel Grid
  tSt     Float
  stSg    Float
  phiPoSg Float
  alphaSg Float
  rcSg    Float

  // Inextensible Reinforcement — Steel Strip
  bSs     Float
  phiPoSs Float
  alphaSs Float
  sh      Float
  d60     Float
  d10     Float

  // Design Heights and Spacing
  minDesignHeight Float
  maxDesignHeight Float
  sV              Float
  minRl           Float @default(8)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  design  Design  @relation(fields: [designId], references: [id], onDelete: Cascade)
}

// ─── Precast Panel Face Design ────────────────────────────────────────────────

model PanelFaceDesign {
  id        String   @id @default(cuid())
  projectId String
  designId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Material Properties
  fc Float
  fy Float

  // Panel Geometry
  lPanel    Float
  hPanel    Float
  tPanel    Float
  ssr       Float
  cCoverPos Float
  cCoverNeg Float

  // Reinforcement (bar number and spacing)
  barNumVert  Float
  spacingVert Float
  barNumHor   Float
  spacingHor  Float

  // Loads from internal stability analysis
  huStr Float
  huEe  Float

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  design  Design  @relation(fields: [designId], references: [id], onDelete: Cascade)
}
